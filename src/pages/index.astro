---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import { siteContent, identity } from "../config";
---

<Layout seo={siteContent.seo}>
  <main class="profile">
    <header class="intro">
      <Image
        src={identity.photo}
        alt={identity.name}
        width={78}
        height={96}
        class="portrait"
      />

      <p class="kicker">{identity.name} · {identity.location}</p>
      <h1>
        <em>Pragmatic educator,</em><br />
        founder &amp; <em>occasional maker.</em>
      </h1>
      <p class="intro-copy">{siteContent.hero.description}</p>
    </header>

    <section class="project" aria-labelledby="project-title">
      <h2 id="project-title" class="brand-line">
        <span aria-hidden="true">✦</span> Building education differently
      </h2>
      <img
        class="project-strip"
        src="/images/education-product-triptych.webp"
        alt="Placeholder education product interfaces displayed on three phones"
      />
      <p>
        I’m building a modern tuition business where strong teaching meets
        thoughtful technology. The goal is simple: make excellent learning more
        personal, measurable, and accessible.
      </p>
    </section>

    <section aria-labelledby="now-title">
      <h2 id="now-title" class="section-title">Now</h2>
      <div class="rows">
        {
          siteContent.hero.meta.map((item) => (
            <div class="row">
              <span>{item.label}</span>
              <span>{item.value}</span>
            </div>
          ))
        }
      </div>
    </section>

    <section aria-labelledby="focus-title">
      <h2 id="focus-title" class="section-title">What I’m building</h2>
      <p class="section-intro">
        Three ideas guide the work. They keep the business useful, human, and
        focused on outcomes that matter.
      </p>
      <div class="rows focus-rows">
        {
          siteContent.focus.map((item, index) => (
            <article class="focus-row">
              <div class="row-heading">
                <span>{item.title}</span>
                <span class="row-index">0{index + 1}</span>
              </div>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section aria-labelledby="about-title">
      <h2 id="about-title" class="section-title">Scenes from the work</h2>
      <p class="section-intro">{siteContent.about.lead}</p>
      <img
        class="work-collage"
        src="/images/education-work-collage.webp"
        alt="Placeholder collage of teaching, planning, and collaborative workshop scenes"
      />
      <p class="caption">Placeholder imagery for workshops, teaching, and building.</p>
      <p class="about-copy">{siteContent.about.body}</p>
    </section>
  </main>
</Layout>

<style>
  .profile {
    width: min(100%, 470px);
    margin: 0 auto;
    padding: 96px 24px 80px;
  }

  .intro {
    margin-bottom: 78px;
  }

  .portrait {
    display: block;
    width: 78px;
    height: 96px;
    object-fit: cover;
    object-position: 50% 25%;
    border-radius: 36px 36px 22px 22px;
    margin-bottom: 28px;
    filter: saturate(0.86) contrast(1.02);
  }

  .kicker,
  .section-title {
    margin: 0;
    font-size: 11px;
    font-weight: 650;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .kicker {
    margin-bottom: 18px;
    color: var(--quiet);
  }

  h1 {
    margin: 0 0 22px;
    font-family: "Instrument Serif", Georgia, serif;
    font-size: clamp(43px, 10vw, 58px);
    font-weight: 400;
    line-height: 0.96;
    letter-spacing: -0.035em;
  }

  h1 em {
    font-weight: 400;
  }

  .intro-copy,
  section > p,
  .focus-row p {
    font-size: 14px;
    line-height: 1.58;
    color: var(--muted);
  }

  .intro-copy {
    max-width: 390px;
    margin: 0;
  }

  section {
    margin-top: 70px;
  }

  .project {
    margin-top: 0;
  }

  .brand-line {
    display: flex;
    align-items: center;
    gap: 7px;
    margin: 0 0 14px;
    font-size: 13px;
    font-weight: 650;
    letter-spacing: -0.01em;
  }

  .project-strip,
  .work-collage {
    display: block;
    width: 100%;
    object-fit: cover;
    background: #171918;
    border: 1px solid var(--line);
  }

  .project-strip {
    aspect-ratio: 2.25 / 1;
    border-radius: 7px;
  }

  .project p {
    margin: 14px 0 0;
  }

  .section-title {
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line);
  }

  .section-intro {
    margin: -4px 0 18px;
  }

  .rows {
    border-top: 1px solid var(--line);
  }

  .section-title + .rows {
    border-top: 0;
  }

  .row {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid var(--line);
    font-size: 13px;
  }

  .row span:first-child {
    font-weight: 650;
  }

  .row span:last-child {
    color: var(--quiet);
    text-align: right;
  }

  .focus-row {
    padding: 15px 0 16px;
    border-bottom: 1px solid var(--line);
  }

  .row-heading {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    font-size: 13px;
    font-weight: 650;
  }

  .row-index {
    font-size: 11px;
    font-style: italic;
    font-weight: 400;
    color: var(--quiet);
  }

  .focus-row p {
    margin: 7px 36px 0 0;
    font-size: 13px;
  }

  .work-collage {
    aspect-ratio: 1 / 1.28;
    object-position: center top;
    border-radius: 7px;
  }

  .caption {
    margin: 8px 0 0;
    font-size: 10px;
    font-style: italic;
    color: var(--quiet);
  }

  .about-copy {
    margin: 20px 0 0;
  }

  @media (max-width: 540px) {
    .profile {
      padding: 68px 22px 56px;
    }

    .intro {
      margin-bottom: 62px;
    }

    section {
      margin-top: 58px;
    }
  }
</style>
