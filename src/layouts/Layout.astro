---
import { identity } from "../config";
import type { SEOInfo } from "../config";

interface Props {
  seo: SEOInfo;
  navVariant?: "home" | "post";
}

const { seo, navVariant = "home" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.image} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="page-shell">
      {
        navVariant === "post" && (
          <nav class="post-nav">
            <a href="/">← {identity.handle}</a>
          </nav>
        )
      }

      <slot />

      <footer class="site-footer">
        <span>© 2026 {identity.name}</span>
        <span>Made in {identity.location}</span>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Inter";
    src: url("/fonts/InterVariable.woff2") format("woff2");
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  :root {
    color-scheme: dark;
    --paper: #0c0d0d;
    --ink: #f1f0e9;
    --muted: #b3b2aa;
    --quiet: #777872;
    --line: #292b29;
    --fg: var(--ink);
    --faint: var(--quiet);
    --accent: #9bcdb9;
    --hover: #171918;
    --card: #151716;
  }

  * {
    box-sizing: border-box;
  }

  html {
    min-width: 320px;
    background: var(--paper);
  }

  body {
    margin: 0;
    color: var(--ink);
    background:
      radial-gradient(circle at 35% -2%, rgba(111, 47, 76, 0.34), transparent 23rem),
      radial-gradient(circle at 67% 0%, rgba(42, 80, 111, 0.32), transparent 24rem),
      radial-gradient(circle at 84% 2%, rgba(52, 90, 67, 0.24), transparent 20rem),
      var(--paper);
    font-family: "Inter", Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
  }

  a {
    color: inherit;
    text-underline-offset: 3px;
  }

  img {
    max-width: 100%;
  }

  .page-shell {
    min-height: 100vh;
  }

  .post-nav,
  .site-footer {
    width: min(calc(100% - 48px), 422px);
    margin-inline: auto;
  }

  .post-nav {
    padding-top: 36px;
    font-size: 12px;
  }

  .post-nav a {
    text-decoration: none;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    padding: 20px 0 54px;
    border-top: 1px solid var(--line);
    color: var(--quiet);
    font-size: 10px;
  }

  @media (max-width: 540px) {
    .post-nav,
    .site-footer {
      width: calc(100% - 44px);
    }

    .site-footer {
      padding-bottom: 36px;
    }
  }
</style>
