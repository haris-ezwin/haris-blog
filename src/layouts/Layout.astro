---
import { identity } from "../config";
import type { SEOInfo } from "../config";

interface Props {
  seo: SEOInfo;
  navVariant?: "home" | "post";
}

const { seo, navVariant = "home" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:image" content={seo.image} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="frame">
      {/* ===== NAV ===== */}
      <nav class="nav">
        {
          navVariant === "post" ? (
            <Fragment>
              <a class="brand" href="/">{identity.handle}</a>
              <div class="nav-right">
                <a class="nav-link" href="/#writing">← all writing</a>
              </div>
            </Fragment>
          ) : (
            <Fragment>
              <a class="brand" href="#top">{identity.handle}</a>
              <div class="nav-right">
                <a class="nav-link" href="#about">about</a>
                <a class="nav-link" href="#focus">focus</a>
                <a class="nav-link" href="#writing">writing</a>
                <a class="nav-link" href="#contact">contact</a>
              </div>
            </Fragment>
          )
        }
      </nav>

      <slot />

      {/* ===== FOOTER ===== */}
      <footer class="site-footer">
        <span>© 2026 {identity.name}</span>
        <span>{identity.location}</span>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0e0e11;
    --fg: #f4f4f5;
    --muted: #9a9aa2;
    --faint: #67676f;
    --line: #232327;
    --card: #16161a;
    --accent: #5b8cff;
    --btn-bg: #f4f4f5;
    --btn-fg: #0e0e11;
    --hover: #16161a;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    -webkit-font-smoothing: antialiased;
    transition: background 0.25s, color 0.25s;
  }

  a {
    color: inherit;
  }

  .mono {
    font-family: "Space Mono", monospace;
  }

  /* ===== Layout frame ===== */
  .frame {
    max-width: 1100px;
    margin: 0 auto;
    border-left: 1px solid var(--line);
    border-right: 1px solid var(--line);
    min-height: 100vh;
    transition: border-color 0.25s;
  }

  /* ===== Nav ===== */
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--bg);
    padding: 22px 44px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--line);
    transition: background 0.25s, border-color 0.25s;
  }

  .brand {
    font-family: "Space Mono", monospace;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--fg);
  }

  .nav-right {
    display: flex;
    gap: 30px;
    align-items: center;
    font-family: "Space Mono", monospace;
    font-size: 12.5px;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  .nav-link {
    text-decoration: none;
  }
  .nav-link:hover {
    color: var(--fg);
  }

  /* ===== Footer ===== */
  .site-footer {
    border-top: 1px solid var(--line);
    padding: 26px 44px;
    display: flex;
    justify-content: space-between;
    font-family: "Space Mono", monospace;
    font-size: 11.5px;
    color: var(--faint);
    letter-spacing: 0.04em;
  }

  /* ===== Mono section label ===== */
  .section-label {
    font-family: "Space Mono", monospace;
    font-size: 12px;
    color: var(--faint);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 720px) {
    .frame {
      border-left: none;
      border-right: none;
    }
    .nav {
      padding: 14px 18px;
    }
    .nav-right {
      gap: 16px;
      font-size: 11.5px;
    }
    .site-footer {
      padding: 22px 18px;
      font-size: 11px;
    }
  }

  @media (max-width: 520px) {
    .nav-right .nav-link {
      display: none;
    }
  }
</style>
