---
import Layout from "./Layout.astro";
import type { SEOInfo } from "../config";

interface Props {
  seo: SEOInfo;
  eyebrow: string;
  title: string;
  intro?: string;
}

const { seo, eyebrow, title, intro } = Astro.props;
---

<Layout seo={seo} navVariant="post">
  <main class="editorial-page">
    <header class="page-intro">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      {intro && <p class="lede">{intro}</p>}
    </header>

    <div class="page-content">
      <slot />
    </div>
  </main>
</Layout>

<style is:global>
  .editorial-page {
    width: min(100%, 470px);
    margin: 0 auto;
    padding: 78px 24px 80px;
  }

  .page-intro {
    margin-bottom: 64px;
  }

  .eyebrow,
  .page-content h2 {
    margin: 0;
    font-size: 11px;
    font-weight: 650;
    letter-spacing: 0.11em;
    text-transform: uppercase;
  }

  .eyebrow {
    margin-bottom: 18px;
    color: var(--quiet);
  }

  .editorial-page h1 {
    margin: 0 0 22px;
    font-family: "Instrument Serif", Georgia, serif;
    font-size: clamp(52px, 12vw, 70px);
    font-weight: 400;
    line-height: 0.94;
    letter-spacing: -0.04em;
  }

  .lede,
  .page-content p,
  .page-content li {
    font-size: 14px;
    line-height: 1.62;
    color: var(--muted);
  }

  .lede {
    max-width: 400px;
    margin: 0;
  }

  .page-content section {
    margin-top: 62px;
  }

  .page-content section:first-child {
    margin-top: 0;
  }

  .page-content h2 {
    margin-bottom: 18px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--line);
    color: var(--ink);
  }

  .page-content p {
    margin: 0 0 16px;
  }

  .page-content ol,
  .page-content ul {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .page-content li {
    position: relative;
    padding: 14px 0 14px 34px;
    border-bottom: 1px solid var(--line);
  }

  .page-content li::before {
    content: attr(data-index);
    position: absolute;
    top: 16px;
    left: 0;
    color: var(--quiet);
    font-size: 10px;
    font-style: italic;
  }

  .page-content li strong {
    display: block;
    margin-bottom: 4px;
    color: var(--ink);
    font-size: 13px;
  }

  .script-card {
    margin-top: 20px;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 7px;
    background: rgba(255, 255, 255, 0.025);
    font-family: "Instrument Serif", Georgia, serif;
    font-size: 23px;
    line-height: 1.28;
    color: var(--ink);
  }

  @media (max-width: 540px) {
    .editorial-page {
      padding: 58px 22px 56px;
    }

    .page-intro {
      margin-bottom: 52px;
    }

    .page-content section {
      margin-top: 52px;
    }
  }
</style>
